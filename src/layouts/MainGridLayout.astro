---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import TOC from "@components/widget/TOC.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "4.5rem";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 w-full mx-auto" class:list={[""]}>
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar></Navbar>
    </div>
</div>

<!-- Banner -->
{siteConfig.banner.enable && <div id="banner-wrapper" class={`absolute z-10 w-full transition duration-700 overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <ImageWrapper id="banner" alt="Banner image of the blog" class:list={["object-cover h-full transition duration-700 opacity-0 scale-105"]}
                  src={siteConfig.banner.src} position={siteConfig.banner.position}
    >
    </ImageWrapper>
</div>}

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <div class="relative w-full mx-auto pointer-events-auto">
        <div id="main-grid" class="transition duration-700 w-full left-0 right-0 flex mx-auto min-h-[calc(100vh-4.5rem)]"
        >
            <!-- 1. Sidebar Spacer (真实的挤压占位符) -->
            <div id="sidebar-spacer" class="w-[20rem] transition-all duration-300 ease-in-out flex-shrink-0 hidden lg:block"></div>

            <!-- 2. Sidebar Body (Fixed 定位，支持悬浮展开) -->
            <aside id="main-sidebar" class="fixed left-0 top-[4.5rem] bottom-0 w-[20rem] z-40 transition-all duration-300 ease-in-out bg-[var(--card-bg)] border-r border-[var(--line-color)] overflow-y-auto hide-scrollbar group hover:shadow-2xl">
                <SideBar headings={headings} title={title}></SideBar>
            </aside>

            <!-- 3. Main Content Area -->
            <main id="swup-container" class="transition-swup-fade flex-grow px-4 py-4 pr-[18rem]">
                <div id="content-wrapper" class="onload-animation max-w-4xl mx-auto">
                    <slot></slot>
                    <div class="footer col-span-2 onload-animation hidden lg:block mt-8 text-center">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <!-- Right TOC (Floating) -->
            {headings.length > 0 && (
                <div id="right-toc-wrapper" class="fixed top-[5.5rem] right-4 w-[16rem] hidden xl:block z-40 transition-all duration-300">
                    <div class="card-base p-4 max-h-[calc(100vh-8rem)] overflow-y-auto hide-scrollbar">
                        <div class="text-sm font-bold text-black/40 dark:text-white/40 mb-3 px-2 uppercase tracking-wider border-b border-[var(--line-color)] pb-2">目录</div>
                        <TOC headings={headings}></TOC>
                    </div>
                </div>
            )}
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<style is:global>
/* 侧边栏折叠状态下的样式 */
.sidebar-collapsed #sidebar-spacer {
    width: 4.5rem !important;
}
.sidebar-collapsed #main-sidebar {
    width: 4.5rem !important;
}
/* 悬浮展开态 */
.sidebar-collapsed #main-sidebar:hover {
    width: 20rem !important;
    box-shadow: 10px 0 30px -10px rgba(0,0,0,0.1);
}
/* 同步 SideBar 组件内部的迷你态 */
.sidebar-collapsed #main-sidebar #sidebar {
    padding: 0.5rem !important;
}
.sidebar-collapsed #main-sidebar:not(:hover) #sidebar {
    /* 迷你态下传递类名给子组件 */
}
</style>
</Layout>
