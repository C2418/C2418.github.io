---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import TOC from "@components/widget/TOC.astro";
import type { MarkdownHeading } from "astro";
import { siteConfig } from "../config";
import Layout from "./Layout.astro";

interface Props {
        title?: string;
        banner?: string;
        description?: string;
        lang?: string;
        setOGTypeArticle?: boolean;
        headings?: MarkdownHeading[];
}

const {
        title,
        banner,
        description,
        lang,
        setOGTypeArticle,
        headings = [],
} = Astro.props;
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar Wrapper -->
<div id="top-row" class="z-50 pointer-events-none relative w-full mx-auto">
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all h-[4.5rem]">
        <Navbar></Navbar>
    </div>
</div>

<!-- 全局包裹器 (Page Wrapper) -->
<div class="flex w-full overflow-hidden bg-gray-50 h-[calc(100vh-4.5rem)]">
    
    <!-- 左侧仿 Gmail 边栏 -->
    <div 
        id="sidebar-placeholder" 
        class="relative flex-shrink-0 transition-all duration-500 cubic-bezier-expo bg-white hidden lg:block w-[250px] will-change-[width]"
    >
        <aside 
            id="main-sidebar" 
            class="absolute top-0 left-0 bottom-0 z-40 transition-all duration-500 cubic-bezier-expo bg-white border-r border-gray-200 overflow-y-auto hide-scrollbar w-[250px] flex flex-col will-change-[width,box-shadow]"
        >
             <!-- 强制锁定内部宽度，防止动画过程中的文字抖动 -->
             <div class="w-[250px] flex-shrink-0 overflow-hidden">
                <SideBar headings={headings} title={title}></SideBar>
             </div>
        </aside>
    </div>

    <!-- 中间沉浸式阅读区 -->
    <div id="main-scroll-container" class="flex-1 min-w-0 flex overflow-y-auto px-6 py-6 gap-6 relative hide-scrollbar">
        
        <article class="flex-1 min-w-0 bg-white rounded-2xl shadow-sm p-8 md:p-12 h-fit overflow-hidden">
            <div id="swup-container" class="transition-swup-fade">
                <slot></slot>
                <div class="footer mt-12 text-center text-gray-400">
                    <Footer></Footer>
                </div>
            </div>
            <BackToTop></BackToTop>
        </article>

        <!-- 右侧悬浮目录 -->
        {headings.length > 0 && (
            <aside id="toc-wrapper" class="w-[260px] flex-shrink-0 sticky top-6 hidden xl:block h-fit">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 max-h-[calc(100vh-10rem)] overflow-y-auto hide-scrollbar">
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4 px-2 border-b border-gray-50 pb-2">目录索引</h3>
                    <TOC headings={headings}></TOC>
                </div>
            </aside>
        )}
    </div>
</div>

<style is:global>
    /* 导出苹果级贝塞尔曲线 */
    .cubic-bezier-expo {
        transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1) !important;
    }

    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    :target {
        scroll-margin-top: 1.5rem;
    }

    /* 侧边栏折叠态样式 */
    .sidebar-collapsed #sidebar-placeholder {
        width: 72px;
    }
    .sidebar-collapsed #main-sidebar {
        width: 72px;
    }

    /* 状态 C：悬浮展开 */
    .sidebar-collapsed #main-sidebar.is-hovered {
        width: 250px;
        box-shadow: 20px 0 50px -10px rgba(0,0,0,0.12); /* 更柔和且深邃的投影 */
    }

    /* 全局滚动平滑补丁 */
    #main-scroll-container {
        scroll-behavior: smooth;
    }
</style>

<script is:inline>
    function initSidebar() {
        const toggleBtn = document.getElementById('sidebar-toggle');
        const placeholder = document.getElementById('sidebar-placeholder');
        const sidebar = document.getElementById('main-sidebar');
        const container = document.body;
        
        if (!toggleBtn || !placeholder || !sidebar) return;

        let isPinned = localStorage.getItem('sidebar-pinned') !== 'false';
        let hoverTimer = null;

        const updateUI = () => {
            if (isPinned) {
                container.classList.remove('sidebar-collapsed');
                sidebar.classList.remove('is-hovered');
            } else {
                container.classList.add('sidebar-collapsed');
            }
        };

        updateUI();

        toggleBtn.onclick = (e) => {
            e.preventDefault();
            isPinned = !isPinned;
            localStorage.setItem('sidebar-pinned', isPinned);
            updateUI();
        };

        sidebar.onmouseenter = () => {
            if (isPinned) return;
            clearTimeout(hoverTimer);
            hoverTimer = setTimeout(() => {
                sidebar.classList.add('is-hovered');
            }, 100); // 稍微缩短一点延迟，感觉更灵敏
        };

        sidebar.onmouseleave = () => {
            if (isPinned) return;
            clearTimeout(hoverTimer);
            sidebar.classList.remove('is-hovered');
        };
    }

    function initTOCJump() {
        const scrollContainer = document.getElementById('main-scroll-container');
        if (!scrollContainer) return;

        document.querySelectorAll('.toc-item').forEach(item => {
            item.onclick = (e) => {
                e.preventDefault();
                const id = decodeURIComponent(item.hash.substring(1));
                const target = document.getElementById(id);
                if (target) {
                    const targetTop = target.getBoundingClientRect().top;
                    const containerTop = scrollContainer.getBoundingClientRect().top;
                    const currentScroll = scrollContainer.scrollTop;
                    const absoluteTop = targetTop - containerTop + currentScroll - 24;
                    
                    scrollContainer.scrollTo({
                        top: absoluteTop,
                        behavior: 'smooth'
                    });
                    history.pushState(null, '', `#${id}`);
                }
            };
        });
    }

    initSidebar();
    initTOCJump();
    
    document.addEventListener('astro:after-swap', () => {
        initSidebar();
        initTOCJump();
    });
</script>
</Layout>
