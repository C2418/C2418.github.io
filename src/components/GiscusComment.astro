<div class="giscus-container mt-10">
    <script src="https://giscus.app/client.js"
            data-repo="C2418/C2418.github.io"
            data-repo-id="R_kgDONG6u6Q"
            data-category="Announcements"
            data-category-id="DIC_kwDONG6u6c4Cj09-"
            data-mapping="pathname"
            data-strict="0"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="top"
            data-theme="preferred_color_scheme"
            data-lang="zh-CN"
            data-loading="lazy"
            crossorigin="anonymous"
            async>
    </script>
</div>

<script is:inline>
    function updateGiscusTheme() {
        const theme = document.documentElement.classList.contains('dark') ? 'transparent_dark' : 'light';
        const iframe = document.querySelector('iframe.giscus-frame');
        if (!iframe) return;
        iframe.contentWindow.postMessage({
            giscus: { setConfig: { theme } }
        }, 'https://giscus.app');
    }

    // Initial sync
    setTimeout(updateGiscusTheme, 2000);

    // Watch for theme changes on html tag
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
                updateGiscusTheme();
            }
        });
    });

    observer.observe(document.documentElement, { attributes: true });

    // Handle Swup page transitions
    document.addEventListener('astro:after-swap', updateGiscusTheme);
</script>
