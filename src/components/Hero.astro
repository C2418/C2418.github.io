---
import { profileConfig } from "@/config";
import { Icon } from "astro-icon/components";
import avatarImg from "../assets/images/avatar.jpg";

const { class: className } = Astro.props;

const badges = [
  { name: 'Docker', color: 'bg-blue-600/10 text-blue-600 border-blue-600/20' },
  { name: 'Zero Trust', color: 'bg-emerald-600/10 text-emerald-600 border-emerald-600/20' },
  { name: 'Node.js', color: 'bg-green-600/10 text-green-600 border-green-600/20' },
  { name: 'Astro', color: 'bg-orange-600/10 text-orange-600 border-orange-600/20' },
];
---

<div class:list={["flex flex-col items-center justify-center py-12 px-4 mb-8 rounded-3xl glass-panel bg-dot-grid onload-animation", className]}>
    <!-- Avatar Area -->
    <div class="relative group mb-6">
        <div class="absolute -inset-1 bg-gradient-to-r from-sky-500 to-blue-600 rounded-full blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative w-32 h-32 rounded-full border-4 border-white dark:border-zinc-800 shadow-2xl overflow-hidden bg-zinc-100 dark:bg-zinc-800">
            <img src={avatarImg.src} alt="Avatar" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" onerror="this.src='/avatar.png'; this.onerror=null;" />
        </div>
    </div>

    <!-- Typewriter Title -->
    <h1 class="text-3xl md:text-4xl font-bold mb-4 tracking-tight text-zinc-800 dark:text-zinc-100 min-h-[1.5em] flex items-center">
        <span id="typewriter"></span><span id="cursor" class="animate-pulse ml-1 text-blue-500">_</span>  
    </h1>

    <!-- Bio -->
    <p class="text-zinc-500 dark:text-zinc-400 mb-8 max-w-md text-center leading-relaxed">    
        {profileConfig.bio}
    </p>

    <!-- Tech Badges -->
    <div class="flex flex-wrap justify-center gap-3">
        {badges.map(badge => (
            <span class:list={[
                "px-4 py-1.5 rounded-full text-sm font-medium border transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 cursor-default",
                badge.color
            ]}>
                {badge.name}
            </span>
        ))}
    </div>
</div>

<script is:inline>
    (function() {
        let typingTimeout;
        function startTypewriter() {
            if (typingTimeout) clearTimeout(typingTimeout);
            
            const text = "你好，我是 2418。欢迎来到我的极客门户。";
            const container = document.getElementById('typewriter');
            if (!container) return;

            container.textContent = '';
            let i = 0;
            const speed = 100;

            function type() {
                if (i < text.length) {
                    container.textContent += text.charAt(i);
                    i++;
                    typingTimeout = setTimeout(type, speed);
                } else {
                    const cursor = document.getElementById('cursor');
                    if (cursor) cursor.classList.add('animate-pulse');
                }
            }
            type();
        }

        document.addEventListener('astro:page-load', startTypewriter);
        
        if (document.readyState === 'complete') {
            startTypewriter();
        } else {
            window.addEventListener('load', startTypewriter);
        }
    })();
</script>

<style is:global>
    .glass-panel {
        @apply bg-white/70 dark:bg-zinc-900/60 backdrop-blur-xl border border-white/20 dark:border-white/10 shadow-xl;
    }
    .bg-dot-grid {
        background-image: radial-gradient(circle, #8882 1px, transparent 1px);
        background-size: 20px 20px;
    }
    .onload-animation {
        opacity: 0;
        animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes slide-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
