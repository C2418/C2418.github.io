---
import { Icon } from "astro-icon/components";
import { navBarConfig, siteConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../types/config";
import { url } from "../utils/url-utils";
import LightDarkSwitch from "./LightDarkSwitch.svelte";
import Search from "./Search.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import NavMenuPanel from "./widget/NavMenuPanel.astro";
import { execSync } from "child_process";

const className = Astro.props.class;

let links: NavBarLink[] = navBarConfig.links.map(
        (item: NavBarLink | LinkPreset): NavBarLink => {
                if (typeof item === "number") {
                        return LinkPresets[item];
                }
                return item;
        },
);

// 获取最新推送时间 (Build Time)
let formattedTime = "";
try {
    const lastCommitTime = execSync("git log -1 --format=%cI").toString().trim();
    formattedTime = new Date(lastCommitTime).toLocaleString("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false
    });
} catch (e) {
    formattedTime = new Date().toLocaleString("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false
    });
}
---
<div id="navbar" class="fixed top-0 left-0 right-0 z-50 onload-animation">
    <div class="absolute h-8 left-0 right-0 -top-8 bg-[var(--card-bg)] transition"></div> <!-- used for onload animation -->
    <div class:list={[
        className,
        "card-base !overflow-visible w-full h-[4.5rem] !rounded-t-none mx-auto flex items-center justify-between px-4"]}>
        <div class="flex items-center gap-2">
            <button id="sidebar-toggle" aria-label="Toggle Sidebar" class="btn-plain scale-animation rounded-full h-12 w-12 active:scale-90 flex items-center justify-center hover:bg-black/5 dark:hover:bg-white/5 text-[var(--primary)]">
                <Icon name="material-symbols:menu-rounded" class="text-[1.5rem]"></Icon>
            </button>
            <a href={url('/')} class="btn-plain scale-animation rounded-lg h-[3.25rem] px-2 font-bold active:scale-95">
                <div class="flex flex-row text-[var(--primary)] items-center text-md">
                    <Icon name="material-symbols:home-outline-rounded" class="text-[1.75rem] mb-1 mr-2" />
                    <div class="flex flex-col items-start justify-center">
                        <span class="leading-none">{siteConfig.title}</span>
                        <span class="text-[9px] font-normal opacity-40 mt-1 whitespace-nowrap leading-none">Push: {formattedTime}</span>
                    </div>
                </div>
            </a>
        </div>

        <div class="hidden md:flex">
            {links.map((l) => {
                return <a aria-label={l.name} href={l.external ? l.url : url(l.url)} target={l.external ? "_blank" : null}
                          class="btn-plain scale-animation rounded-lg h-11 font-bold px-5 active:scale-95"
                >
                    <div class="flex items-center text-sm">
                        {l.name}
                        {l.external && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.875rem] transition -translate-y-[1px] ml-1 text-black/[0.2] dark:text-white/[0.2]"></Icon>}      
                    </div>
                </a>;
            })}
        </div>
        <div class="flex">
            <!--<SearchPanel client:load>-->
            <Search client:only="svelte"></Search>
            {!siteConfig.themeColor.fixed && (
                    <button aria-label="Display Settings" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="display-settings-switch">
                        <Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
                    </button>
            )}
            <LightDarkSwitch client:only="svelte"></LightDarkSwitch>
            <button aria-label="Menu" name="Nav Menu" class="btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 md:!hidden" id="nav-menu-switch">
                <Icon name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
            </button>
        </div>
        <NavMenuPanel links={links}></NavMenuPanel>
        <DisplaySettings client:only="svelte"></DisplaySettings>
    </div>
</div>

<script>
function loadButtonScript() {
    // Sidebar toggle logic (State A vs State B)
    let sidebarToggle = document.getElementById("sidebar-toggle");
    let isPinned = localStorage.getItem('sidebar-pinned') !== 'false';

    const updateSidebarState = (pinned) => {
        const body = document.body;
        const sidebar = document.getElementById("sidebar");
        if (pinned) {
            body.classList.remove("sidebar-collapsed");
            sidebar?.classList.remove("collapsed-mode");
        } else {
            body.classList.add("sidebar-collapsed");
            sidebar?.classList.add("collapsed-mode");
        }
        localStorage.setItem('sidebar-pinned', pinned.toString());
    };

    updateSidebarState(isPinned);

    if (sidebarToggle) {
        sidebarToggle.onclick = function() {
            isPinned = !isPinned;
            updateSidebarState(isPinned);
        };
    }

    // Hover logic (State C)
    const mainSidebar = document.getElementById("main-sidebar");
    const sidebarInner = document.getElementById("sidebar");
    let hoverTimeout;

    if (mainSidebar && sidebarInner) {
        mainSidebar.addEventListener('mouseenter', () => {
            if (!isPinned) {
                hoverTimeout = setTimeout(() => {
                    sidebarInner.classList.remove("collapsed-mode");
                }, 150);
            }
        });
        mainSidebar.addEventListener('mouseleave', () => {
            if (!isPinned) {
                clearTimeout(hoverTimeout);
                sidebarInner.classList.add("collapsed-mode");
            }
        });
    }
}

loadButtonScript();
document.addEventListener('astro:after-swap', loadButtonScript);
</script>
